{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build stm32-debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "stm32-debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}